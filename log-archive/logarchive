#!/bin/bash

# Log Archive Tool
# Compresses logs from a specified directory and stores them with timestamp
# Usage: log-archive <log-directory>

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to show usage
show_usage() {
    echo "Usage: $0 <log-directory>"
    echo ""
    echo "Arguments:"
    echo "  log-directory    Path to the directory containing logs to archive"
    echo ""
    echo "Examples:"
    echo "  $0 /var/log"
    echo "  $0 /home/user/app/logs"
    echo "  $0 ./logs"
    echo ""
    echo "The tool will:"
    echo "  - Create a timestamped tar.gz archive of all files in the log directory"
    echo "  - Store the archive in an 'archives' subdirectory"
    echo "  - Log the archiving operation with timestamp"
    echo "  - Optionally remove original log files after successful archiving"
}

# Function to validate directory
validate_directory() {
    local dir="$1"
    
    if [[ ! -d "$dir" ]]; then
        print_error "Directory '$dir' does not exist"
        return 1
    fi
    
    if [[ ! -r "$dir" ]]; then
        print_error "Directory '$dir' is not readable"
        return 1
    fi
    
    # Check if directory has any files
    if [[ -z "$(ls -A "$dir" 2>/dev/null)" ]]; then
        print_warning "Directory '$dir' is empty"
        return 1
    fi
    
    return 0
}

# Function to create archive directory
create_archive_dir() {
    local log_dir="$1"
    local archive_dir="$log_dir/archives"
    
    if [[ ! -d "$archive_dir" ]]; then
        print_info "Creating archive directory: $archive_dir"
        mkdir -p "$archive_dir"
    fi
    
    echo "$archive_dir"
}

# Function to generate timestamp
generate_timestamp() {
    date +"%Y%m%d_%H%M%S"
}

# Function to get archive filename
get_archive_filename() {
    local timestamp="$1"
    echo "logs_archive_${timestamp}.tar.gz"
}

# Function to create tar.gz archive
create_archive() {
    local log_dir="$1"
    local archive_dir="$2"
    local archive_file="$3"
    local archive_path="$archive_dir/$archive_file"
    
    print_info "Creating archive: $archive_file"
    print_info "Source directory: $log_dir"
    print_info "Archive location: $archive_path"
    
    # Create list of files to archive (excluding the archives directory)
    local files_to_archive=()
    while IFS= read -r -d '' file; do
        # Skip files in the archives directory
        if [[ "$file" != "$archive_dir"* ]]; then
            files_to_archive+=("$file")
        fi
    done < <(find "$log_dir" -type f -print0)
    
    if [[ ${#files_to_archive[@]} -eq 0 ]]; then
        print_warning "No files found to archive"
        return 1
    fi
    
    local file_count=${#files_to_archive[@]}
    print_info "Found $file_count files to archive"
    
    # Create the archive using tar with compression
    if tar -czf "$archive_path" "${files_to_archive[@]}" 2>/dev/null; then
        local archive_size=$(du -h "$archive_path" | cut -f1)
        print_success "Archive created successfully: $archive_file ($archive_size)"
        return 0
    else
        print_error "Failed to create archive"
        return 1
    fi
}

# Function to log archiving operation
log_operation() {
    local log_dir="$1"
    local archive_file="$2"
    local archive_dir="$3"
    local log_file="$archive_dir/archive.log"
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    local archive_size=$(du -h "$archive_dir/$archive_file" 2>/dev/null | cut -f1 || echo "unknown")
    local file_count=$(tar -tzf "$archive_dir/$archive_file" 2>/dev/null | wc -l || echo "unknown")
    
    echo "[$timestamp] Archive created: $archive_file | Size: $archive_size | Files: $file_count | Source: $log_dir" >> "$log_file"
    print_info "Operation logged to: $log_file"
}

# Function to ask for confirmation to remove original files
ask_remove_originals() {
    local log_dir="$1"
    local archive_dir="$2"
    
    echo ""
    print_warning "Do you want to remove the original log files after successful archiving?"
    print_warning "This will delete all files in $log_dir (except the archives directory)"
    echo -n "Type 'yes' to confirm removal of original files: "
    read -r response
    
    if [[ "$response" == "yes" ]]; then
        print_info "Removing original log files..."
        find "$log_dir" -type f ! -path "$archive_dir/*" -delete
        print_success "Original log files removed"
    else
        print_info "Original log files preserved"
    fi
}

# Function to display archive summary
show_summary() {
    local archive_dir="$1"
    local archive_file="$2"
    local archive_path="$archive_dir/$archive_file"
    
    echo ""
    echo "=================================="
    echo "       ARCHIVE SUMMARY           "
    echo "=================================="
    echo "Archive file: $archive_file"
    echo "Archive path: $archive_path"
    echo "Archive size: $(du -h "$archive_path" | cut -f1)"
    echo "Files archived: $(tar -tzf "$archive_path" | wc -l)"
    echo "Created: $(date)"
    echo "=================================="
}

# Main function
main() {
    # Check if help is requested
    if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
        show_usage
        exit 0
    fi
    
    # Check if log directory argument is provided
    if [[ $# -ne 1 ]]; then
        print_error "Invalid number of arguments"
        echo ""
        show_usage
        exit 1
    fi
    
    local log_dir="$1"
    
    # Convert to absolute path
    log_dir=$(realpath "$log_dir")
    
    print_info "Starting log archiving process..."
    print_info "Log directory: $log_dir"
    
    # Validate the log directory
    if ! validate_directory "$log_dir"; then
        exit 1
    fi
    
    # Create archive directory
    local archive_dir
    archive_dir=$(create_archive_dir "$log_dir")
    
    # Generate timestamp and archive filename
    local timestamp
    timestamp=$(generate_timestamp)
    local archive_file
    archive_file=$(get_archive_filename "$timestamp")
    
    # Create the archive
    if create_archive "$log_dir" "$archive_dir" "$archive_file"; then
        # Log the operation
        log_operation "$log_dir" "$archive_file" "$archive_dir"
        
        # Show summary
        show_summary "$archive_dir" "$archive_file"
        
        # Ask if user wants to remove original files
        ask_remove_originals "$log_dir" "$archive_dir"
        
        print_success "Log archiving completed successfully!"
    else
        print_error "Log archiving failed!"
        exit 1
    fi
}

# Check if script is being sourced or executed
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
